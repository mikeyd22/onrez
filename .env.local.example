# Supabase (get from https://supabase.com dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mapbox (get from https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# Google Maps (Places API) — https://console.cloud.google.com/apis/credentials
# Enable Places API and Maps JavaScript API for address autocomplete
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: Overpass API for nearby amenities (defaults to public instance)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Optional: For seed script — email of an existing Supabase Auth user to own seeded listings
# SEED_OWNER_EMAIL=your@email.com
